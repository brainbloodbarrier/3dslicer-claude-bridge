{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "slicer-bridge": {
      "type": "local",
      "enabled": true,
      "command": [
        "uv",
        "--directory",
        "..",
        "run",
        "slicer-mcp"
      ],
      "environment": {
        "SLICER_URL": "http://localhost:2016"
      },
      "timeout": 10000
    }
  }
}
